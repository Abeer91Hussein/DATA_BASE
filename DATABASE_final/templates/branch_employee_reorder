<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Reorder Requests</title>
<style>
html, body {
    height: 100%;
    margin: 0;
    padding: 0;
}

body{
    font-family: 'Times New Roman', Times, serif;
    position: relative;
    overflow-x: hidden;
}

body::before{
content: "";
position:fixed;
top: 0;
left: 0;
width: 100%;
height: 100%;
background-image: url("{{ url_for('static', filename='492005453_1078773277617540_8286173066551137313_n.jpg') }}");
background-size: cover;
background-position: center;
background-repeat: no-repeat;
filter: blur();
z-index: -1;
}
.navbar{
    width: 100%;
    background-color: rgb(0, 0, 0);
    padding: 15px 40px;
    position:fixed;
    top: 0;
    left: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color:white;
    z-index: 1000;
    box-shadow: 0 2px 10px rgb(0,0,0);
    box-sizing: border-box;
}
.navbar h2{
  margin: 0;
  font-size: 25px;  
}
.navbar .btn{
    background-color: #410a05;
    color: white;
    padding: 8px 16px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Times New Roman', Times, serif;
    font-size: 16px;
    transition: 0.3s;
    margin-left: 10px;
}
.navbar .btn:hover {
    background-color: #931342;
    transform: scale(1.04);

}

.container {
padding-top: 100px;
display: flex;
flex-direction: column;
align-items: center;
gap: 30px;
padding-bottom: 50px;
}



</style>
